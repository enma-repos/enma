{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "AllowedHosts": "*",

  "Auth": {
    "RefreshTokenLifetimeDays": 0,
    "StateCacheTtlMinutes": 0,
    "RedirectBaseAddress": "",
    "CookieDomain": ""
  },

  "Postgres": {
    "ConnectionString": ""
  },

  "Redis": {
    "ConnectionString": "",
    "KeyPrefix": "",
    "Database": 0
  },

  "Jwt": {
    "SecretKey": "",
    "ExpiresMinutes": 0
  },

  "GoogleProvider": {
    "BaseAddress": "",
    "TimeoutSeconds": 0,
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUrl": "",
    "RequireEmailVerified": false,
    "ClockSkewSeconds": 0
  },

  "AdminGrpc": {
    "Address": "",
    "DeadlineMs": 0
  },

  "SuperAdmin": {
    "EmailsRaw": ""
  }
}
