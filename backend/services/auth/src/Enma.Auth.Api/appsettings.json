{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Yarp": "Information"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "AllowedHosts": "*",

  "Auth": {
    "RefreshTokenLifetimeDays": 30,
    "StateCacheTtlMinutes": 10,
    "RedirectBaseAddress": "http://localhost:3000"
  },
  
  "Postgres": {
    "ConnectionString": ""
  },
  
  "Redis": {
    "ConnectionString": "redis:6379",
    "KeyPrefix": "auth",
    "Database": 0
  },

  "Jwt": {
    "SecretKey": "",
    "ExpiresMinutes": 10
  },

  "GoogleProvider": {
    "BaseAddress": "https://oauth2.googleapis.com/",
    "TimeoutSeconds": 10,
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUrl": "",
    "RequireEmailVerified": true,
    "ClockSkewSeconds": 60
  },

  "AdminGrpc": {
    "Address": "http://admin:8081",
    "DeadlineMs": 3000
  }
}
