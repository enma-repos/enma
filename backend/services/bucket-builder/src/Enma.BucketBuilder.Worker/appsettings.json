{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Quartz": "Warning"
    }
  },
  "ClickHouse": {
    "ConnectionString": "Host=localhost;Protocol=http;Port=8123;Database=enma;Username=default;Password=",
    "CommandTimeoutSeconds": 30
  },
  "MongoDb": {
    "ConnectionString": "mongodb://enma:enma@localhost:27017/enma?authSource=admin",
    "DatabaseName": "enma"
  },
  "BucketBuilder": {
    "PollIntervalSeconds": 10,
    "SafetyLagSeconds": 30,
    "MaxWindowsPerTick": 12,
    "LeaseTimeoutSeconds": 120,
    "Pipeline": "bucket-builder",
    "ShardIndex": 0,
    "ShardCount": 1,
    "InitialLookbackHours": 1
  }
}
