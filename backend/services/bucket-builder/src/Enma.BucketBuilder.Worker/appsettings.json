{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Quartz": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "ClickHouse": {
    "ConnectionString": "",
    "CommandTimeoutSeconds": 0
  },
  "MongoDb": {
    "ConnectionString": "",
    "DatabaseName": ""
  },
  "BucketBuilder": {
    "PollIntervalSeconds": 0,
    "SafetyLagSeconds": 0,
    "MaxWindowsPerTick": 0,
    "LeaseTimeoutSeconds": 0,
    "Pipeline": "",
    "ShardIndex": 0,
    "ShardCount": 0,
    "InitialLookbackHours": 0
  }
}
