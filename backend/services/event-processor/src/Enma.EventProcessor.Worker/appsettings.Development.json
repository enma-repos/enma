{
  "RabbitMq": {
    "ConnectionString": "amqp://guest:guest@localhost:5672/"
  },
  "EventProcessor": {
    "RabbitMq": {
      "EndpointName": "enma-event-processor-events",
      "PrefetchCount": 512,
      "BatchMessageLimit": 500,
      "BatchTimeLimitSeconds": 2,
      "BatchConcurrencyLimit": 1,
      "RetryCount": 3,
      "RetryIntervalSeconds": 5
    }
  },
  "ClickHouse": {
    "ConnectionString": "Host=localhost;Protocol=http;Port=8123;Database=enma;Username=default;Password=;JsonWriteMode=Binary",
    "ApplyMigrationsOnStartup": true,
    "CommandTimeoutSeconds": 30
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "KeyPrefix": "enma",
    "Database": 0
  },
  "AdminGrpc": {
    "Address": "http://localhost:8081",
    "DeadlineMs": 3000
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
