{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Yarp": "Information"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },

  "AdminGrpc": {
    "Address": "http://admin:8081",
    "DeadlineMs": 3000
  },

  "Redis": {
    "ConnectionString": "redis:6379",
    "KeyPrefix": "SDK_GW",
    "Database": 0
  },

  "SdkAuth": {
    "CacheTtlMinutes": 5
  },

  "ReverseProxyConfigFilePath": "/app/proxy/api-gateway.json",

  "ReverseProxy": {
    "Routes": {
      "ingest-route": {
        "ClusterId": "ingest-cluster",
        "Match": {
          "Path": "/api/ingest/{**catch-all}"
        },
      }
    },
    "Clusters": {
      "ingest-cluster": {
        "Destinations": {
          "auth": {
            "Address": "http://ingest:8080/"
          }
        }
      }
    }
  }
}