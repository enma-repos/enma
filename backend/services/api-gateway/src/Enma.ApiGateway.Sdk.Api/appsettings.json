{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Yarp": "Information"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },

  "ReverseProxyConfigFilePath": "/app/proxy/api-gateway.json",

  "ReverseProxy": {
    "Routes": {
      "ingest-route": {
        "ClusterId": "ingest-cluster",
        "Match": {
          "Path": "/api/ingest/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/ingest/"
          },
          {
            "PathPrefix": "/api"
          }
        ]
      }
    },
    "Clusters": {
      "ingest-cluster": {
        "Destinations": {
          "auth": {
            "Address": "http://ingest:8080/"
          }
        }
      }
    }
  }
}