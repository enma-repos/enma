{
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Yarp": "Information"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  
  "ReverseProxyConfigFilePath": "/app/proxy/api-gateway.json",
  
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/admin/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/admin/auth"
          },
          {
            "PathPrefix": "/api"
          }
        ]
      },
      "project-route": {
        "ClusterId": "project-cluster",
        "Match": {
          "Path": "/api/admin/project/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/admin/project"
          },
          {
            "PathPrefix": "/api"
          }
        ]
      },
      "analytics-route": {
        "ClusterId": "analytics-cluster",
        "Match": {
          "Path": "/api/admin/analytics/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/admin/analytics"
          },
          {
            "PathPrefix": "/api"
          }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": {
            "Address": "http://auth:8080/"
          }
        }
      },
      "project-cluster": {
        "Destinations": {
          "project": {
            "Address": "http://project:8080/"
          }
        }
      },
      "analytics-cluster": {
        "Destinations": {
          "analytics": {
            "Address": "http://analytics:8080/"
          }
        }
      }
    }
  }
}