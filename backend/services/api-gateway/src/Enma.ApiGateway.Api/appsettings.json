{
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://10.8.1.2:3000"
    ]
  },
  
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Yarp": "Information"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  
  "ReverseProxyConfigFilePath": "/app/proxy/api-gateway.json",
  
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "admin-route": {
        "ClusterId": "admin-cluster",
        "Match": {
          "Path": "/api/admin/{**catch-all}"
        }
      },
      "analytics-route": {
        "ClusterId": "analytics-cluster",
        "Match": {
          "Path": "/api/analytics/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": {
            "Address": "http://auth:8080/"
          }
        }
      },
      "admin-cluster": {
        "Destinations": {
          "admin": {
            "Address": "http://admin:8080/"
          }
        }
      },
      "analytics-cluster": {
        "Destinations": {
          "analytics": {
            "Address": "http://analytics:8080/"
          }
        }
      }
    }
  }
}