# ---------- Compose ----------
COMPOSE_PROJECT_NAME=enma

# ---------- Global / ASP.NET ----------
ASPNETCORE_ENVIRONMENT=Development

# ---------- Postgres ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=enma
POSTGRES_USER=enma
POSTGRES_PASSWORD=enma
# Common Npgsql style:
POSTGRES_CONNECTION_STRING=Host=${POSTGRES_HOST};Port=${POSTGRES_PORT};Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}

# ---------- ClickHouse ----------
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_DB=enma
CLICKHOUSE_USER=enma
CLICKHOUSE_PASSWORD=enma
# HTTP style (often used):
CLICKHOUSE_HTTP_URL=http://${CLICKHOUSE_HOST}:${CLICKHOUSE_HTTP_PORT}
# Native connection (some drivers use different formats; keep components too):
CLICKHOUSE_CONNECTION=Host=${CLICKHOUSE_HOST};Port=${CLICKHOUSE_NATIVE_PORT};Database=${CLICKHOUSE_DB};Username=${CLICKHOUSE_USER};Password=${CLICKHOUSE_PASSWORD}

# ---------- MongoDB ----------
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=enma
MONGO_USER=enma
MONGO_PASSWORD=enma
MONGO_CONNECTION_STRING=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@${MONGO_HOST}:${MONGO_PORT}/${MONGO_DB}?authSource=admin

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CONNECTION_STRING=${REDIS_HOST}:${REDIS_PORT}

# ---------- RabbitMQ ----------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=enma
RABBITMQ_PASSWORD=enma
RABBITMQ_VHOST=/
RABBITMQ_URI=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}${RABBITMQ_VHOST}

# ---------- Service base URLs (inside docker network) ----------
# Useful for api-gateway routing / inter-service HTTP calls
API_GATEWAY_BASEURL=http://api-gateway:8080
ANALYTICS_BASEURL=http://analytics:8080
AUTH_BASEURL=http://auth:8080
INGEST_BASEURL=http://ingest:8080
ADMIN_BASEURL=http://admin:8080

# ---------- Local published ports (host machine) ----------
# Only needed if you want to reference them in docs/scripts.
API_GATEWAY_PORT=8080
ANALYTICS_PORT=8081
AUTH_PORT=8082
INGEST_PORT=8083
ADMIN_PORT=8084

# ---------- RabbitMQ Management UI (host) ----------
RABBITMQ_MANAGEMENT_PORT=15672

API_KEY_PEPPER=some_key