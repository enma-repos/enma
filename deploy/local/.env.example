# ---------- Compose ----------
COMPOSE_PROJECT_NAME=enma

# ---------- Global / ASP.NET ----------
ASPNETCORE_ENVIRONMENT=Development

# ---------- Postgres ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=enma
POSTGRES_USER=enma
POSTGRES_PASSWORD=enma

# ---------- ClickHouse ----------
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_DB=enma
CLICKHOUSE_USER=enma
CLICKHOUSE_PASSWORD=enma
# HTTP style (often used):
CLICKHOUSE_HTTP_URL=http://${CLICKHOUSE_HOST}:${CLICKHOUSE_HTTP_PORT}
# Native connection (some drivers use different formats; keep components too):
CLICKHOUSE_CONNECTION=Host=${CLICKHOUSE_HOST};Port=${CLICKHOUSE_NATIVE_PORT};Database=${CLICKHOUSE_DB};Username=${CLICKHOUSE_USER};Password=${CLICKHOUSE_PASSWORD}

# ---------- MongoDB ----------
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=enma
MONGO_USER=enma
MONGO_PASSWORD=enma
MONGO_CONNECTION_STRING=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@${MONGO_HOST}:${MONGO_PORT}/${MONGO_DB}?authSource=admin

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CONNECTION_STRING=redis:6379
REDIS_KEY_PREFIX=auth
REDIS_DATABASE=0

# ---------- Redis (SDK API Gateway) ----------
SDK_GW_REDIS_KEY_PREFIX=sdk-gw
SDK_GW_REDIS_DATABASE=2
SDK_AUTH_CACHE_TTL_MINUTES=5

# ---------- Redis (EventProcessor) ----------
EP_REDIS_KEY_PREFIX=enma
EP_REDIS_DATABASE=1

# ---------- Redis (Admin) ----------
ADMIN_REDIS_KEY_PREFIX=enma
ADMIN_REDIS_DATABASE=1

# ---------- RabbitMQ ----------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=enma
RABBITMQ_PASSWORD=enma
RABBITMQ_VHOST=/
RABBITMQ_URI=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}${RABBITMQ_VHOST}

# ---------- Auth / JWT ----------
AUTH_JWT_SECRET=dev_secret_change_me

# ---------- Google OAuth (Auth) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/v1/external/google/callback
GOOGLE_BASE_ADDRESS=https://oauth2.googleapis.com/
GOOGLE_TIMEOUT_SECONDS=10
GOOGLE_REQUIRE_EMAIL_VERIFIED=true
GOOGLE_CLOCK_SKEW_SECONDS=60

# ---------- Auth Options ----------
AUTH_REFRESH_TOKEN_LIFETIME_DAYS=30
AUTH_STATE_CACHE_TTL_MINUTES=10
AUTH_REDIRECT_BASE_ADDRESS=http://localhost:3000

# ---------- JWT ----------
JWT_EXPIRES_MINUTES=10

# ---------- Admin ----------
API_KEY_PEPPER=some_key

# ---------- Redis (Auth) ----------
REDIS_KEY_PREFIX=auth
REDIS_DATABASE=0

# ---------- Redis (EventProcessor) ----------
EP_REDIS_KEY_PREFIX=enma
EP_REDIS_DATABASE=1

# ---------- Redis (Admin) ----------
ADMIN_REDIS_KEY_PREFIX=enma
ADMIN_REDIS_DATABASE=1

# ---------- Admin gRPC ----------
ADMIN_GRPC_ADDRESS=http://admin:8081
ADMIN_GRPC_DEADLINE_MS=3000

# ---------- Redis (SDK API Gateway) ----------
SDK_GW_REDIS_KEY_PREFIX=sdk-gw
SDK_GW_REDIS_DATABASE=2

# ---------- SDK Auth ----------
SDK_AUTH_CACHE_TTL_MINUTES=5

# ---------- EventProcessor RabbitMq ----------
EP_RABBITMQ_ENDPOINT_NAME=enma-event-processor-events
EP_RABBITMQ_PREFETCH_COUNT=512
EP_RABBITMQ_BATCH_MESSAGE_LIMIT=500
EP_RABBITMQ_BATCH_TIME_LIMIT_SECONDS=2
EP_RABBITMQ_BATCH_CONCURRENCY_LIMIT=1
EP_RABBITMQ_RETRY_COUNT=3
EP_RABBITMQ_RETRY_INTERVAL_SECONDS=5

# ---------- ClickHouse Options ----------
CLICKHOUSE_APPLY_MIGRATIONS=true
CLICKHOUSE_COMMAND_TIMEOUT=30

# ---------- BucketBuilder ----------
BB_POLL_INTERVAL_SECONDS=10
BB_SAFETY_LAG_SECONDS=30
BB_MAX_WINDOWS_PER_TICK=12
BB_LEASE_TIMEOUT_SECONDS=120
BB_PIPELINE=bucket-builder
BB_SHARD_INDEX=0
BB_SHARD_COUNT=1
BB_INITIAL_LOOKBACK_HOURS=1
