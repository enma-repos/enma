# ---------- Compose ----------
COMPOSE_PROJECT_NAME=enma

# ---------- Global / ASP.NET ----------
ASPNETCORE_ENVIRONMENT=Development

# ---------- Postgres ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=enma
POSTGRES_USER=enma
POSTGRES_PASSWORD=enma

# ---------- ClickHouse ----------
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_DB=enma
CLICKHOUSE_USER=enma
CLICKHOUSE_PASSWORD=enma
# HTTP style (often used):
CLICKHOUSE_HTTP_URL=http://${CLICKHOUSE_HOST}:${CLICKHOUSE_HTTP_PORT}
# Native connection (some drivers use different formats; keep components too):
CLICKHOUSE_CONNECTION=Host=${CLICKHOUSE_HOST};Port=${CLICKHOUSE_NATIVE_PORT};Database=${CLICKHOUSE_DB};Username=${CLICKHOUSE_USER};Password=${CLICKHOUSE_PASSWORD}

# ---------- MongoDB ----------
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=enma
MONGO_USER=enma
MONGO_PASSWORD=enma
MONGO_CONNECTION_STRING=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@${MONGO_HOST}:${MONGO_PORT}/${MONGO_DB}?authSource=admin

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CONNECTION_STRING=${REDIS_HOST}:${REDIS_PORT}

# ---------- RabbitMQ ----------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=enma
RABBITMQ_PASSWORD=enma
RABBITMQ_VHOST=/
RABBITMQ_URI=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}${RABBITMQ_VHOST}

# ---------- Auth / JWT ----------
AUTH_JWT_SECRET=dev_secret_change_me

# ---------- Google OAuth (Auth) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/v1/external/google/callback

# ---------- Admin ----------
API_KEY_PEPPER=some_key
