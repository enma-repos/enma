# ---------- Postgres ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=enma
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ---------- ClickHouse ----------
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DB=enma
CLICKHOUSE_USER=enma
CLICKHOUSE_PASSWORD=CHANGE_ME_STRONG_PASSWORD
CLICKHOUSE_APPLY_MIGRATIONS=true
CLICKHOUSE_COMMAND_TIMEOUT=30

# ---------- MongoDB ----------
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=enma
MONGO_USER=enma
MONGO_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MONGO_CONNECTION_STRING=mongodb://enma:CHANGE_ME_STRONG_PASSWORD@mongo:27017/enma?authSource=admin

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CONNECTION_STRING=redis:6379
REDIS_KEY_PREFIX=auth
REDIS_DATABASE=0

# ---------- RabbitMQ ----------
RABBITMQ_USER=enma
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_PASSWORD
RABBITMQ_URI=amqp://enma:CHANGE_ME_STRONG_PASSWORD@rabbitmq:5672/

# ---------- Auth / JWT ----------
AUTH_JWT_SECRET=CHANGE_ME_GENERATE_LONG_RANDOM_STRING
JWT_EXPIRES_MINUTES=10

# ---------- Google OAuth ----------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
AUTH_GOOGLE_REDIRECT_URL=https://api.YOUR_DOMAIN/api/auth/v1/external/google/callback
GOOGLE_BASE_ADDRESS=https://oauth2.googleapis.com/
GOOGLE_TIMEOUT_SECONDS=10
GOOGLE_REQUIRE_EMAIL_VERIFIED=true
GOOGLE_CLOCK_SKEW_SECONDS=60

# ---------- Auth Options ----------
AUTH_REFRESH_TOKEN_LIFETIME_DAYS=30
AUTH_STATE_CACHE_TTL_MINUTES=10
AUTH_REDIRECT_BASE_ADDRESS=https://YOUR_DOMAIN

# ---------- Admin ----------
API_KEY_PEPPER=CHANGE_ME_RANDOM_STRING
ADMIN_GRPC_ADDRESS=http://admin:8081
ADMIN_GRPC_DEADLINE_MS=3000

# ---------- EventProcessor ----------
EP_RABBITMQ_ENDPOINT_NAME=enma-event-processor-events
EP_RABBITMQ_PREFETCH_COUNT=512
EP_RABBITMQ_BATCH_MESSAGE_LIMIT=500
EP_RABBITMQ_BATCH_TIME_LIMIT_SECONDS=2
EP_RABBITMQ_BATCH_CONCURRENCY_LIMIT=1
EP_RABBITMQ_RETRY_COUNT=3
EP_RABBITMQ_RETRY_INTERVAL_SECONDS=5

# ---------- BucketBuilder ----------
BB_POLL_INTERVAL_SECONDS=10
BB_SAFETY_LAG_SECONDS=30
BB_MAX_WINDOWS_PER_TICK=12
BB_LEASE_TIMEOUT_SECONDS=120
BB_PIPELINE=bucket-builder
BB_SHARD_INDEX=0
BB_SHARD_COUNT=1
BB_INITIAL_LOOKBACK_HOURS=1

# ---------- Frontend ----------
NEXT_PUBLIC_API_GATEWAY_URL=https://api.YOUR_DOMAIN
